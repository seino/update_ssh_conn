# SSH接続更新スクリプト - 環境変数設定
# このファイルを .env にコピーして、実際の値を設定してください

# === 通知設定 ===
# 通知サービスの種類 (teams, slack, chatwork)
NOTIFICATION_TYPE=teams

# 通知を有効/無効にする (true/false)
ENABLE_NOTIFICATIONS=true

# Microsoft Teams Webhook URL（NOTIFICATION_TYPE=teamsの場合に必要）
TEAMS_WEBHOOK_URL=https://your-organization.webhook.office.com/webhookb2/...

# Slack Webhook URL（NOTIFICATION_TYPE=slackの場合に必要）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Chatwork設定（NOTIFICATION_TYPE=chatworkの場合に必要）
CHATWORK_API_TOKEN=your_chatwork_api_token_here
CHATWORK_ROOM_ID=your_room_id_here

# === ファイルパス設定 ===
# ValueServerのCSVファイルパス（cron実行用に絶対パス推奨）
VALUESERVER_CSV=/home/user/apps/update_ssh_conn/csv/list_valueserver.csv

# CoreServerのCSVファイルパス（cron実行用に絶対パス推奨）
CORESERVER_CSV=/home/user/apps/update_ssh_conn/csv/list_coreserver.csv

# === IPアドレス設定 ===
# 固定IPアドレス（設定すると動的取得をスキップ）
# 例: FIXED_IP_ADDRESS=123.456.789.012
FIXED_IP_ADDRESS=

# IPアドレス取得用のURL（固定IPが未設定の場合に使用）
IP_CHECK_URL=http://dyn.value-domain.com/cgi-bin/dyn.fcg?ip

# === リクエスト設定 ===

# リクエスト間の遅延時間（秒）
REQUEST_DELAY=2

# レート制限時の追加遅延時間（秒）
RATE_LIMIT_DELAY=4

# === リトライ設定 ===
# 最大リトライ回数
MAX_RETRIES=3

# リトライ時のバックオフ係数（待機時間の増加率）
RETRY_BACKOFF_FACTOR=2.0